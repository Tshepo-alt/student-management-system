    <script>
        // ============================================
        // AUTHENTICATION
        // ============================================
        const token = localStorage.getItem('access_token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');

        if (!token) {
            window.location.href = 'login.html';
        }

        const logoImage = document.getElementById('logoImage');
        if (logoImage) logoImage.onerror = () => logoImage.style.display = 'none';

        // ============================================
        // DEMO DATA (would come from API)
        // ============================================
        // Define department weightings
        const departmentWeightings = {
            'FICT': { assignment: 0.25, mid: 0.25, final: 0.50 },   // ICT
            'FET': { assignment: 0.20, mid: 0.20, final: 0.60 },    // Engineering
            'default': { assignment: 0.15, mid: 0.15, final: 0.70 } // Other faculties
        };

        const demoData = {
            student: {
                name: user.first_name && user.last_name ? `${user.first_name} ${user.last_name}` : (user.username || 'Student'),
                number: user.student_number || 'GIPS2024001',
                program: 'Bachelor of Science in Computer Science',
                faculty: 'FICT',  // Faculty code to determine weightings
                campus: 'Gaborone Main Campus',
                enrollment_year: 2024,
                current_year: 2
            },
            current_gpa: 3.45,
            cumulative_gpa: 3.28,
            credits_earned: 96,
            total_credits_required: 480,
            academic_status: 'good_standing',
            is_government_sponsored: user.is_government_sponsored || false,
            semesters: [
                {
                    semester: 'Semester 1',
                    academic_year: '2024/2025',
                    year_of_study: 1,
                    gpa: 3.2,
                    credits_attempted: 60,
                    credits_earned: 54,
                    courses: [
                        { code: 'CS101', name: 'Introduction to Programming', credits: 12, assignment: 78, mid: 75, final: 80, overall: 0, grade: '' },
                        { code: 'CS102', name: 'Computer Architecture', credits: 12, assignment: 72, mid: 70, final: 74, overall: 0, grade: '' },
                        { code: 'CS103', name: 'Mathematics for Computing', credits: 12, assignment: 85, mid: 82, final: 88, overall: 0, grade: '' },
                        { code: 'CS104', name: 'Web Development Fundamentals', credits: 12, assignment: 80, mid: 78, final: 82, overall: 0, grade: '' },
                        { code: 'CS105', name: 'Database Systems', credits: 12, assignment: 74, mid: 72, final: 76, overall: 0, grade: '' }
                    ]
                },
                {
                    semester: 'Semester 2',
                    academic_year: '2024/2025',
                    year_of_study: 1,
                    gpa: 3.35,
                    credits_attempted: 60,
                    credits_earned: 60,
                    courses: [
                        { code: 'CS201', name: 'Data Structures & Algorithms', credits: 12, assignment: 86, mid: 84, final: 88, overall: 0, grade: '' },
                        { code: 'CS202', name: 'Software Engineering', credits: 12, assignment: 82, mid: 80, final: 84, overall: 0, grade: '' },
                        { code: 'CS203', name: 'Operating Systems', credits: 12, assignment: 76, mid: 74, final: 78, overall: 0, grade: '' },
                        { code: 'CS204', name: 'Networking & Communication', credits: 12, assignment: 79, mid: 76, final: 82, overall: 0, grade: '' },
                        { code: 'CS205', name: 'Object Oriented Programming', credits: 12, assignment: 91, mid: 88, final: 94, overall: 0, grade: '' }
                    ]
                },
                {
                    semester: 'Semester 1',
                    academic_year: '2025/2026',
                    year_of_study: 2,
                    gpa: 3.65,
                    credits_attempted: 60,
                    credits_earned: 60,
                    courses: [
                        { code: 'CS301', name: 'Artificial Intelligence', credits: 12, assignment: 94, mid: 90, final: 96, overall: 0, grade: '' },
                        { code: 'CS302', name: 'Database Management Systems', credits: 12, assignment: 88, mid: 86, final: 90, overall: 0, grade: '' },
                        { code: 'CS303', name: 'Web Application Development', credits: 12, assignment: 87, mid: 84, final: 90, overall: 0, grade: '' },
                        { code: 'CS304', name: 'Cyber Security Fundamentals', credits: 12, assignment: 83, mid: 80, final: 86, overall: 0, grade: '' },
                        { code: 'CS305', name: 'Mobile App Development', credits: 12, assignment: 92, mid: 88, final: 94, overall: 0, grade: '' }
                    ]
                }
            ]
        };

        // Helper: compute overall mark based on department weightings
        function computeOverallMark(course, faculty) {
            const weights = departmentWeightings[faculty] || departmentWeightings.default;
            let overall = (course.assignment * weights.assignment) +
                          (course.mid * weights.mid) +
                          (course.final * weights.final);
            return Math.round(overall * 100) / 100;
        }

        // Grade mapping based on overall mark (standard 0-100)
        function getGrade(mark) {
            if (mark >= 80) return 'A';
            if (mark >= 75) return 'A-';
            if (mark >= 70) return 'B+';
            if (mark >= 65) return 'B';
            if (mark >= 60) return 'B-';
            if (mark >= 55) return 'C+';
            if (mark >= 50) return 'C';
            if (mark >= 45) return 'C-';
            if (mark >= 40) return 'D';
            return 'F';
        }

        function getGradeClass(grade) {
            if (!grade) return '';
            if (grade.startsWith('A')) return 'grade-A';
            if (grade.startsWith('B')) return 'grade-B';
            if (grade.startsWith('C')) return 'grade-C';
            if (grade === 'D') return 'grade-D';
            if (grade === 'F') return 'grade-F';
            return '';
        }

        function getClassStanding(gpa) {
            if (gpa >= 3.6) return { name: 'First Class', class: 'standing-first', desc: 'Excellent Performance' };
            if (gpa >= 3.0) return { name: 'Second Class Upper', class: 'standing-second', desc: 'Good Performance' };
            if (gpa >= 2.5) return { name: 'Second Class Lower', class: 'standing-pass', desc: 'Satisfactory Performance' };
            if (gpa >= 2.0) return { name: 'Pass', class: 'standing-pass', desc: 'Minimum Requirements Met' };
            return { name: 'Probation', class: 'standing-probation', desc: 'Academic Warning - Seek Support' };
        }

        // Process demo data: compute overall marks and grades
        function processResults(data) {
            const faculty = data.student.faculty;
            for (const sem of data.semesters) {
                for (const course of sem.courses) {
                    course.overall = computeOverallMark(course, faculty);
                    course.grade = getGrade(course.overall);
                }
            }
            return data;
        }

        let academicData = processResults(demoData);

        // ============================================
        // RENDER FUNCTIONS
        // ============================================
        function renderGPA() {
            document.getElementById('currentGPA').textContent = academicData.current_gpa.toFixed(2);
            document.getElementById('cumulativeGPA').textContent = academicData.cumulative_gpa.toFixed(2);
            document.getElementById('creditsEarned').textContent = academicData.credits_earned;
            const standing = getClassStanding(academicData.cumulative_gpa);
            document.getElementById('classStandingValue').textContent = standing.name;
            document.getElementById('classStandingDesc').textContent = standing.desc;
            const standingSpan = document.getElementById('classStandingValue');
            if (standingSpan) {
                standingSpan.className = `class-standing ${standing.class}`;
            }

            const gpaStatusSpan = document.getElementById('gpaStatus');
            if (academicData.academic_status === 'probation') {
                gpaStatusSpan.innerHTML = '<span style="color:#e53e3e;">⚠️ Academic Probation</span>';
                document.getElementById('warningBanner').innerHTML = `
                    <div class="warning-banner">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span><strong>Academic Warning:</strong> Your GPA is below 2.0. Please contact your academic advisor for support.</span>
                    </div>
                `;
                document.getElementById('warningBanner').style.display = 'block';
            } else {
                gpaStatusSpan.innerHTML = '<span style="color:#38a169;">✓ Good Standing</span>';
            }

            if (academicData.is_government_sponsored) {
                document.getElementById('infoBanner').innerHTML = `
                    <div class="info-banner">
                        <i class="fas fa-info-circle"></i>
                        <span>You are a government-sponsored student. Your fees are exempt. Exam fees for supplementary/resit/retake apply separately.</span>
                    </div>
                `;
                document.getElementById('infoBanner').style.display = 'block';
            }
        }

        function renderSemesterResults() {
            const container = document.getElementById('semesterResultsContainer');
            if (!academicData.semesters.length) {
                container.innerHTML = '<div class="info-banner"><i class="fas fa-info-circle"></i> No semester results available.</div>';
                return;
            }
            const faculty = academicData.student.faculty;
            const weights = departmentWeightings[faculty] || departmentWeightings.default;
            const weightText = `Assignment ${weights.assignment*100}% / Mid-Sem ${weights.mid*100}% / Final ${weights.final*100}%`;

            container.innerHTML = academicData.semesters.map(sem => `
                <div class="semester-summary">
                    <div class="semester-header">
                        <div class="semester-title">
                            <i class="fas fa-calendar-alt"></i> ${sem.semester} - ${sem.academic_year} (Year ${sem.year_of_study})
                        </div>
                        <div class="semester-stats">
                            <div class="semester-stat"><div class="label">Semester GPA</div><div class="value">${sem.gpa.toFixed(2)}</div></div>
                            <div class="semester-stat"><div class="label">Credits</div><div class="value">${sem.credits_earned}/${sem.credits_attempted}</div></div>
                        </div>
                    </div>
                    <div class="results-table-container">
                        <table class="results-table">
                            <thead>
                                <tr><th>Course Code</th><th>Course Name</th><th>Credits</th><th>Assignment (${weights.assignment*100}%)</th><th>Mid-Sem (${weights.mid*100}%)</th><th>Final Exam (${weights.final*100}%)</th><th>Overall</th><th>Grade</th><th>Status</th> </tr>
                            </thead>
                            <tbody>
                                ${sem.courses.map(c => `
                                    <tr>
                                        <td>${escapeHtml(c.code)}</td>
                                        <td>${escapeHtml(c.name)}</td>
                                        <td>${c.credits}</td>
                                        <td>${c.assignment}%</td>
                                        <td>${c.mid}%</td>
                                        <td>${c.final}%</td>
                                        <td><strong>${c.overall}%</strong></td>
                                        <td class="${getGradeClass(c.grade)}">${c.grade}</td>
                                        <td>${c.grade !== 'F' ? '<span class="credit-pass"><i class="fas fa-check-circle"></i> Passed</span>' : '<span class="credit-fail"><i class="fas fa-times-circle"></i> Failed</span>'}</td>
                                     </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            `).join('');
            // Add weighting note
            const noteDiv = document.createElement('div');
            noteDiv.className = 'info-banner';
            noteDiv.style.marginTop = '15px';
            noteDiv.innerHTML = `<i class="fas fa-chart-simple"></i> Weighting: ${weightText}`;
            container.appendChild(noteDiv);
        }

        function renderTranscript() {
            const container = document.getElementById('transcriptContainer');
            const standing = getClassStanding(academicData.cumulative_gpa);
            const student = academicData.student;

            let transcriptHtml = `
                <div class="semester-summary">
                    <div class="semester-header">
                        <div class="semester-title"><i class="fas fa-file-alt"></i> Official Academic Transcript</div>
                    </div>
                    <div style="margin-bottom: 20px;">
                        <p><strong>Student Name:</strong> ${escapeHtml(student.name)}</p>
                        <p><strong>Student Number:</strong> ${escapeHtml(student.number)}</p>
                        <p><strong>Program:</strong> ${escapeHtml(student.program)}</p>
                        <p><strong>Campus:</strong> ${escapeHtml(student.campus)}</p>
                        <p><strong>Enrollment Year:</strong> ${student.enrollment_year} | <strong>Current Year:</strong> ${student.current_year}</p>
                        <p><strong>Cumulative GPA:</strong> ${academicData.cumulative_gpa.toFixed(2)}</p>
                        <p><strong>Class Standing:</strong> ${standing.name}</p>
                        <p><strong>Total Credits Earned:</strong> ${academicData.credits_earned}</p>
                        <hr style="margin: 15px 0;">
                    </div>
            `;

            const faculty = student.faculty;
            const weights = departmentWeightings[faculty] || departmentWeightings.default;
            const weightText = `Assignment ${weights.assignment*100}% / Mid-Sem ${weights.mid*100}% / Final ${weights.final*100}%`;

            academicData.semesters.forEach(sem => {
                transcriptHtml += `
                    <div class="semester-summary" style="margin-bottom: 20px;">
                        <div class="semester-header">
                            <div class="semester-title"><i class="fas fa-calendar-alt"></i> ${sem.semester} - ${sem.academic_year}</div>
                            <div class="semester-stats">
                                <div class="semester-stat"><div class="label">GPA</div><div class="value">${sem.gpa.toFixed(2)}</div></div>
                                <div class="semester-stat"><div class="label">Credits</div><div class="value">${sem.credits_earned}/${sem.credits_attempted}</div></div>
                            </div>
                        </div>
                        <div class="results-table-container">
                            <table class="results-table">
                                <thead>
                                    <tr><th>Code</th><th>Course Name</th><th>Credits</th><th>Assign</th><th>Mid</th><th>Final</th><th>Overall</th><th>Grade</th> </tr>
                                </thead>
                                <tbody>
                                    ${sem.courses.map(c => `
                                         <tr>
                                            <td>${escapeHtml(c.code)}</td>
                                            <td>${escapeHtml(c.name)}</td>
                                            <td>${c.credits}</td>
                                            <td>${c.assignment}%</td>
                                            <td>${c.mid}%</td>
                                            <td>${c.final}%</td>
                                            <td><strong>${c.overall}%</strong></td>
                                            <td class="${getGradeClass(c.grade)}">${c.grade}</td>
                                         </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    </div>
                `;
            });

            transcriptHtml += `
                    <hr style="margin: 20px 0;">
                    <div style="text-align: right;">
                        <p><strong>Registrar's Signature:</strong> _________________________</p>
                        <p><strong>Date:</strong> ${new Date().toLocaleDateString()}</p>
                        <p style="margin-top: 30px; font-size: 0.8rem;">This is an official academic transcript from GIPS College.</p>
                    </div>
                    <div class="info-banner" style="margin-top: 20px;">
                        <i class="fas fa-chart-simple"></i> Weighting used: ${weightText}
                    </div>
                </div>
            `;
            container.innerHTML = transcriptHtml;
        }

        function renderAcademicProgress() {
            const container = document.getElementById('progressContainer');
            const student = academicData.student;
            const remainingCredits = academicData.total_credits_required - academicData.credits_earned;
            const remainingSemesters = Math.ceil(remainingCredits / 60);
            const completionPercent = (academicData.credits_earned / academicData.total_credits_required * 100).toFixed(1);

            container.innerHTML = `
                <div class="semester-summary">
                    <div class="semester-header">
                        <div class="semester-title"><i class="fas fa-chart-line"></i> Program Completion Progress</div>
                    </div>
                    <div style="margin: 20px 0;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <span>Program Completion</span>
                            <span>${completionPercent}% (${academicData.credits_earned}/${academicData.total_credits_required} credits)</span>
                        </div>
                        <div style="background: #e2e8f0; border-radius: 30px; height: 10px; overflow: hidden;">
                            <div style="width: ${completionPercent}%; background: linear-gradient(90deg, #667eea, #764ba2); height: 100%; border-radius: 30px;"></div>
                        </div>
                    </div>
                    <div class="info-item" style="margin: 10px 0;"><strong>Credits Earned:</strong> ${academicData.credits_earned}</div>
                    <div class="info-item"><strong>Credits Remaining:</strong> ${remainingCredits}</div>
                    <div class="info-item"><strong>Estimated Completion:</strong> ${remainingSemesters} semesters (approx. ${Math.ceil(remainingSemesters/2)} years)</div>
                    <div class="info-item"><strong>Current GPA Trend:</strong> ${academicData.current_gpa > academicData.cumulative_gpa ? '📈 Improving' : (academicData.current_gpa < academicData.cumulative_gpa ? '📉 Declining' : '➡️ Stable')}</div>
                </div>
                <div class="semester-summary">
                    <div class="semester-header">
                        <div class="semester-title"><i class="fas fa-lightbulb"></i> Academic Recommendations</div>
                    </div>
                    <ul style="margin-left: 20px; color: #4a5568;">
                        ${academicData.cumulative_gpa >= 3.5 ? '<li>✓ You are on track for First Class Honors. Maintain your excellent performance!</li>' : ''}
                        ${academicData.cumulative_gpa >= 3.0 && academicData.cumulative_gpa < 3.5 ? '<li>✓ Good performance! Aim for First Class by improving your grades in upcoming semesters.</li>' : ''}
                        ${academicData.cumulative_gpa >= 2.0 && academicData.cumulative_gpa < 3.0 ? '<li>📚 You are meeting minimum requirements. Focus on improving your grades to achieve honors.</li>' : ''}
                        ${academicData.cumulative_gpa < 2.0 ? '<li>⚠️ Your GPA is below 2.0. Please schedule a meeting with your academic advisor immediately.</li>' : ''}
                        <li>📖 Consider joining study groups for challenging courses.</li>
                        <li>💬 Utilize academic support services and tutoring available at the library.</li>
                    </ul>
                </div>
            `;
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ============================================
        // PRINT & DOWNLOAD
        // ============================================
        function printTranscript() {
            window.print();
        }

        function downloadTranscript() {
            alert('📄 PDF download will be available soon. For now, use Print > Save as PDF.');
            window.print();
        }

        // ============================================
        // TAB SWITCHING
        // ============================================
        function setupTabs() {
            const tabs = document.querySelectorAll('.tab-button');
            const contents = document.querySelectorAll('.tab-content');
            tabs.forEach(btn => {
                btn.addEventListener('click', () => {
                    const tabId = btn.getAttribute('data-tab');
                    tabs.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    contents.forEach(c => c.classList.remove('active'));
                    document.getElementById(tabId).classList.add('active');
                });
            });
        }

        // ============================================
        // LOGOUT
        // ============================================
        document.getElementById('logoutLink').addEventListener('click', (e) => {
            e.preventDefault();
            localStorage.clear();
            window.location.href = 'login.html';
        });

        // ============================================
        // INIT
        // ============================================
        function init() {
            renderGPA();
            renderSemesterResults();
            renderTranscript();
            renderAcademicProgress();
            setupTabs();
        }
        init();
    </script>
</body>
</html>