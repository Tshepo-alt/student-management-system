    <!-- Modal -->
    <div id="agreementModal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2 style="margin-bottom: 16px;"><i class="fas fa-file-signature"></i> Acknowledge Rules</h2>
            <p>Please read and confirm that you agree to abide by the GIPS Student Village rules.</p>
            <div id="agreementText" class="agreement-text"></div>
            <div class="checkbox-group">
                <input type="checkbox" id="agreeRules">
                <label>I have read, understood, and agree to all the rules and regulations.</label>
            </div>
            <div id="acknowledgeError" class="error-message"></div>
            <div id="acknowledgeSuccess" class="success-message"></div>
            <button class="btn-primary" onclick="submitAcknowledgment()">Confirm</button>
        </div>
