# ============================================
# FLASK APPLICATION SETTINGS - PRODUCTION
# ============================================
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Flask Secret Key - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=gips-college-secure-key-2026-make-this-long-and-random-32-chars

# JWT Configuration
JWT_SECRET_KEY=gips-college-jwt-secret-key-2026-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ============================================
# DATABASE CONFIGURATION - MYSQL
# ============================================
DATABASE_URL=mysql+pymysql://root:@localhost:3306/gips_college_db
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=gips_college_db
MYSQL_PORT=3306

# Database Pool Settings
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_POOL_PRE_PING=True

# Disable SQL echo in production
SQLALCHEMY_ECHO=False

# Chatbot Database (SQLite - separate from main DB)
CHATBOT_DB_PATH=database/chatbot.db

