# ============================================
# FLASK APPLICATION SETTINGS
# ============================================
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Flask Secret Key - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=gips-college-secure-key-2026-make-this-long-and-random-32-chars

# JWT Configuration
JWT_SECRET_KEY=gips-college-jwt-secret-key-2026-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ============================================
# DATABASE CONFIGURATION - MYSQL
# ============================================
# MySQL Database (ENABLED)
# Note: Password is "Admin" without any special characters
DATABASE_URL=mysql+pymysql://root:Admin@localhost:3306/gips_college_db
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=Admin
MYSQL_DATABASE=gips_college_db
MYSQL_PORT=3306

# Database Pool Settings
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_POOL_PRE_PING=True

# Chatbot Database (SQLite - separate from main DB)
CHATBOT_DB_PATH=database/chatbot.db

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Default Admin Users (these will be created on first run)
ADMIN_EMAILS=admin@gipscollege.edu.bw,director@gipscollege.edu.bw,registrar@gipscollege.edu.bw,itadmin@gipscollege.edu.bw,financeadmin@gipscollege.edu.bw
ADMIN_ROLES=admin,administrator,admin,admin,admin

# Admin Access Levels
ADMIN_ACCESS_LEVELS=full,full,full,full,finance

# Super Admin (highest privilege)
SUPER_ADMIN_EMAIL=admin@gipscollege.edu.bw

