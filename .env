# ============================================
# SYSTEM FEATURES
# ============================================
# Authentication Features
ENABLE_2FA=False
ENABLE_SOCIAL_LOGIN=False
# FIX: Disable email verification for development (or set up email properly)
ENABLE_EMAIL_VERIFICATION=False
ENABLE_PASSWORD_RESET=True

# API Features
ENABLE_API_DOCS=True
ENABLE_API_RATE_LIMITING=True
API_VERSION=v1
API_TITLE=GIPS College Student Management System API
API_DESCRIPTION=Complete API for managing student records, courses, assignments, exams, accommodation, and alumni

# Chatbot Features
ENABLE_CHATBOT=True
ENABLE_CHATBOT_ANALYTICS=True
ENABLE_TICKET_AUTO_CLOSE=True
ENABLE_AUTO_TICKET_ROUTING=True

# Notification Features
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SMS_NOTIFICATIONS=False
ENABLE_PUSH_NOTIFICATIONS=False

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
MAX_CONTENT_LENGTH=52428800  # 50 MB in bytes
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,jpg,jpeg,png,zip,rar,ppt,pptx,xls,xlsx

# Upload subdirectories
UPLOAD_DOCUMENTS=uploads/documents
UPLOAD_ASSIGNMENTS=uploads/assignments
UPLOAD_RESEARCH=uploads/research
UPLOAD_ATTACHMENTS=uploads/attachments
UPLOAD_PROFILE_PICTURES=uploads/profiles

# ============================================
# SESSION AND SECURITY
# ============================================
SESSION_TIMEOUT_MINUTES=30
REMEMBER_ME_DAYS=30
PASSWORD_MIN_LENGTH=8
PASSWORD_COMPLEXITY=medium  # low, medium, high
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_NUMBERS=True
PASSWORD_REQUIRE_SPECIAL=True

# Security Headers
SECURITY_HEADERS_ENABLED=True
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://gipscollege.edu.bw

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_DEFAULT=100 per hour
RATE_LIMIT_AUTH=5 per minute
RATE_LIMIT_API=200 per hour
RATE_LIMIT_CHATBOT=10 per minute
RATE_LIMIT_UPLOAD=20 per hour

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_TYPE=simple  # simple, redis, memcached
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=gips_

# Redis Cache (for production)
# CACHE_TYPE=redis
# CACHE_REDIS_URL=redis://localhost:6379/0
# CACHE_REDIS_PASSWORD=

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10 MB
LOG_BACKUP_COUNT=10
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

