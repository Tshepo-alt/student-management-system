    <div class="container">
        <div class="page-header">
            <h1><i class="fas fa-gavel"></i> Accommodation Rules & Regulations</h1>
            <p>All residents are required to read, understand, and adhere to these rules to maintain a safe, respectful,
                and conducive living environment.</p>
        </div>

        <div class="rules-layout">
            <!-- Sidebar -->
            <div class="rules-sidebar">
                <div class="sidebar-title"><i class="fas fa-list"></i> Categories</div>
                <ul class="rule-categories" id="ruleCategories"></ul>

                <div class="room-info">
                    <h3><i class="fas fa-building"></i> GIPS Student Village</h3>
                    <div class="room-stats">
                        <div class="room-stat">
                            <div class="number">5</div>
                            <div>Blocks</div>
